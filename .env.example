# Required for local run and Docker mount scope.
PALACE_PATH=./palace

# Optional override for config file path (defaults to ./config/palace.json).
APP_CONFIG_FILE=./config/palace.json

# Local bind address for Docker published port.
BIND_HOST=127.0.0.1
PORT=8099
HOST=127.0.0.1

# Optional gunicorn args (default in docker-compose is --reload for dev live updates).
# Example to disable reload: GUNICORN_CMD_ARGS=
GUNICORN_CMD_ARGS=

# Optional public URL for status output.
PUBLIC_URL=https://memory-palace.example.com

# Optional Neo4j/Bolt live graph integration.
# Enable and configure these to power the Neo4j renderer with live queries.
NEO4J_ENABLED=false
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional: if set, docker-up starts cloudflared tunnel profile.
CLOUDFLARED_TUNNEL_TOKEN=
