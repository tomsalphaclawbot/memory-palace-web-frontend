# Required for local run and Docker mount scope.
PALACE_PATH=./palace

# Optional override for config file path (defaults to ./config/palace.json).
APP_CONFIG_FILE=./config/palace.json

# Local bind address for Docker published port.
BIND_HOST=127.0.0.1
PORT=8099
HOST=127.0.0.1

# Optional public URL for status output.
PUBLIC_URL=https://memory-palace.example.com

# Optional: if set, docker-up starts cloudflared tunnel profile.
CLOUDFLARED_TUNNEL_TOKEN=
